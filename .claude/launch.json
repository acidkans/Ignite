{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "backend",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "start:dev"],
      "port": 3001,
      "cwd": "apps/backend"
    },
    {
      "name": "frontend",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["vite", "--port", "5174", "--strictPort"],
      "port": 5174,
      "cwd": "apps/frontend",
      "autoPort": false
    },
    {
      "name": "frontend-pwa-preview",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["vite", "preview", "--port", "4173", "--strictPort"],
      "port": 4173,
      "cwd": "apps/frontend",
      "autoPort": false
    }
  ]
}
